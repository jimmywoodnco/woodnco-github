    },
    {
      "type": "image_picker",
      "id": "walnut_icon",
      "label": "Walnut option image"
    },
    {
      "type": "image_picker",
      "id": "smoke_icon",
      "label": "Smoke 5% option image"
    },
    {
      "type": "image_picker",
      "id": "dark_oak_icon",
      "label": "Dark Oak option image"
    }
  ],
  "presets": [
    {
      "name": "Custom Furniture Product"
    }
  ]
}
{% endschema %}