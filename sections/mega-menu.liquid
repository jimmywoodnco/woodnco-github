<header class="wc-header">
  <div class="wc-header-inner">

    <button type="button" class="wc-mobile-toggle" aria-label="Open menu">
      ☰
    </button>

    <a href="/" class="wc-logo">
      {% if section.settings.logo != blank %}
        <img
          src="{{ section.settings.logo | image_url: width: 260 }}"
          alt="{{ shop.name }}"
        >
      {% else %}
        {{ shop.name }}
      {% endif %}
    </a>

    <nav class="wc-nav">
      <div class="wc-nav-item wc-mega-trigger">
        <button type="button" class="wc-mega-button">
          Collections
          <span>⌄</span>
        </button>

        <div class="wc-mega-menu">
          <div class="wc-mega-inner">

            <div class="wc-mega-col">
              <h3>Browse by Collection</h3>
              {% for collection in collections %}
                {% assign show_item = collection.metafields.custom.show_in_mega_menu.value %}
                {% assign group_name = collection.metafields.custom.mega_menu_group.value %}
                {% assign label_name = collection.metafields.custom.mega_menu_label.value %}

                {% if show_item == true and group_name == 'Browse by Collection' %}
                  <a href="{{ collection.url }}">
                    {{ label_name | default: collection.title }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>

            <div class="wc-mega-col">
              <h3>Browse by Design Line</h3>
              {% for collection in collections %}
                {% assign show_item = collection.metafields.custom.show_in_mega_menu.value %}
                {% assign group_name = collection.metafields.custom.mega_menu_group.value %}
                {% assign label_name = collection.metafields.custom.mega_menu_label.value %}

                {% if show_item == true and group_name == 'Browse by Design Line' %}
                  <a href="{{ collection.url }}">
                    {{ label_name | default: collection.title }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>

            <div class="wc-mega-col">
              <h3>Browse by Room</h3>
              {% for collection in collections %}
                {% assign show_item = collection.metafields.custom.show_in_mega_menu.value %}
                {% assign group_name = collection.metafields.custom.mega_menu_group.value %}
                {% assign label_name = collection.metafields.custom.mega_menu_label.value %}

                {% if show_item == true and group_name == 'Browse by Room' %}
                  <a href="{{ collection.url }}">
                    {{ label_name | default: collection.title }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>

            <div class="wc-mega-col">
              <h3>Browse by Product</h3>
              {% for collection in collections %}
                {% assign show_item = collection.metafields.custom.show_in_mega_menu.value %}
                {% assign group_name = collection.metafields.custom.mega_menu_group.value %}
                {% assign label_name = collection.metafields.custom.mega_menu_label.value %}

                {% if show_item == true and group_name == 'Browse by Product' %}
                  <a href="{{ collection.url }}">
                    {{ label_name | default: collection.title }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>

            <div class="wc-mega-col">
              <h3>Browse by Material</h3>
              {% for collection in collections %}
                {% assign show_item = collection.metafields.custom.show_in_mega_menu.value %}
                {% assign group_name = collection.metafields.custom.mega_menu_group.value %}
                {% assign label_name = collection.metafields.custom.mega_menu_label.value %}

                {% if show_item == true and group_name == 'Browse by Material' %}
                  <a href="{{ collection.url }}">
                    {{ label_name | default: collection.title }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>

          </div>
        </div>
      </div>

      {% if section.settings.main_menu != blank %}
        {% for link in section.settings.main_menu.links %}
          {% unless link.title == 'Collections' %}
            <a href="{{ link.url }}">
              {{ link.title }}
            </a>
          {% endunless %}
        {% endfor %}
      {% endif %}
    </nav>

    <div class="wc-header-actions">
      <a href="/search" class="wc-search">Search</a>

      <a href="{{ routes.cart_url }}" class="wc-cart" aria-label="Cart">
        <span class="wc-cart-icon">🛒</span>
        <span>Cart</span>

        {% if cart.item_count > 0 %}
          <span class="wc-cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>

      {% if section.settings.contact_link != blank %}
        <a href="{{ section.settings.contact_link }}" class="wc-contact">
          Contact Us
        </a>
      {% endif %}
    </div>

  </div>
</header>

<style>
.wc-header {
  background: #f8f4ee;
  border-bottom: 1px solid #e8ded1;
  position: relative;
  z-index: 50;
}

.wc-header-inner {
  width: min(1400px, calc(100% - 48px));
  margin: 0 auto;
  height: 74px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 40px;
}

.wc-logo {
  display: flex;
  align-items: center;
  height: 100%;
  font-size: 24px;
  font-weight: 700;
  color: #3f5f7f;
  text-decoration: none;
}

.wc-logo img {
  max-width: 150px;
  max-height: 62px;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
}

.wc-mobile-toggle {
  display: none;
}

.wc-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 34px;
}

.wc-nav a,
.wc-nav button {
  background: none;
  border: 0;
  padding: 0;
  font: inherit;
  color: #5f5147;
  text-decoration: none;
  cursor: pointer;
  font-size: 15px;
}

.wc-nav a:hover,
.wc-nav button:hover {
  color: #3f5f7f;
}

.wc-nav-item {
  position: static;
}

.wc-mega-button {
  display: flex;
  align-items: center;
  gap: 6px;
  color: #3f5f7f !important;
  border-bottom: 2px solid #3f7faf !important;
  padding-bottom: 4px !important;
}

.wc-mega-menu {
  position: absolute;
  left: 0;
  right: 0;
  top: 74px;
  background: #fffaf4;
  border-top: 1px solid #eadfd2;
  border-bottom: 1px solid #eadfd2;
  box-shadow: 0 18px 40px rgba(0,0,0,.08);
  opacity: 0;
  visibility: hidden;
  transform: translateY(8px);
  transition: all .18s ease;
}

.wc-mega-trigger:hover .wc-mega-menu {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.wc-mega-inner {
  width: min(1400px, calc(100% - 48px));
  margin: 0 auto;
  padding: 42px 0;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 48px;
}

.wc-mega-col h3 {
  margin: 0 0 22px;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: #3f5f7f;
  font-weight: 700;
}

.wc-mega-col a {
  display: block;
  margin-bottom: 16px;
  color: #6f6258;
  text-decoration: none;
  font-size: 15px;
}

.wc-mega-col a:hover {
  color: #3f5f7f;
  text-decoration: underline;
  text-underline-offset: 4px;
}

.wc-header-actions {
  display: flex;
  align-items: center;
  gap: 18px;
}

.wc-search {
  color: #5f5147;
  text-decoration: none;
  font-size: 14px;
}

.wc-cart {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  color: #5f5147;
  text-decoration: none;
  font-size: 14px;
}

.wc-cart:hover {
  color: #3f5f7f;
}

.wc-cart-icon {
  font-size: 17px;
  line-height: 1;
}

.wc-cart-count {
  background: #4f7da8;
  color: #fff;
  min-width: 18px;
  height: 18px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 5px;
}

.wc-contact {
  background: #4f7da8;
  color: #fff;
  padding: 12px 22px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 700;
}

/* Mobile / Tablet */
@media screen and (max-width: 990px) {
  .wc-header {
    z-index: 100;
  }

  .wc-header-inner {
    width: calc(100% - 32px);
    height: 76px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0;
  }

  .wc-mobile-toggle {
    display: block;
    grid-column: 1;
    justify-self: start;
    background: none;
    border: 0;
    font-size: 28px;
    line-height: 1;
    color: #5f5147;
    cursor: pointer;
    padding: 6px;
  }

  .wc-logo {
    grid-column: 2;
    justify-content: center;
    height: auto;
  }

  .wc-logo img {
    max-width: 130px;
    max-height: 60px;
    object-fit: contain;
  }

  .wc-header-actions {
    grid-column: 3;
    justify-self: end;
    display: flex;
    align-items: center;
  }

  .wc-search,
  .wc-contact {
    display: none;
  }

  .wc-cart span:not(.wc-cart-icon):not(.wc-cart-count) {
    display: none;
  }

  .wc-nav {
    display: none;
    position: absolute;
    top: 76px;
    left: 0;
    right: 0;
    background: #fffaf4;
    border-top: 1px solid #eadfd2;
    border-bottom: 1px solid #eadfd2;
    box-shadow: 0 16px 32px rgba(0,0,0,.08);
    padding: 22px 24px;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    z-index: 99;
  }

  .wc-nav.mobile-open {
    display: flex;
  }

  .wc-nav a,
  .wc-nav button {
    font-size: 16px;
    color: #5f5147;
  }

  .wc-mega-trigger {
    width: 100%;
  }

  .wc-mega-button {
    width: 100%;
    justify-content: space-between;
    border-bottom: 0 !important;
    padding-bottom: 0 !important;
  }

  .wc-mega-menu {
    position: static;
    display: none;
    opacity: 1;
    visibility: visible;
    transform: none;
    box-shadow: none;
    border: 0;
    background: transparent;
    width: 100%;
    margin-top: 10px;
  }

  .wc-mega-trigger.mobile-open .wc-mega-menu {
    display: block;
  }

  .wc-mega-inner {
    width: 100%;
    padding: 14px 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .wc-mega-col h3 {
    margin-bottom: 12px;
    font-size: 11px;
  }

  .wc-mega-col a {
    margin-bottom: 10px;
    font-size: 15px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const toggle = document.querySelector('.wc-mobile-toggle');
  const nav = document.querySelector('.wc-nav');
  const megaButton = document.querySelector('.wc-mega-button');
  const megaParent = document.querySelector('.wc-mega-trigger');

  if (toggle && nav) {
    toggle.addEventListener('click', function () {
      nav.classList.toggle('mobile-open');
    });
  }

  if (megaButton && megaParent) {
    megaButton.addEventListener('click', function (event) {
      if (window.innerWidth <= 990) {
        event.preventDefault();
        megaParent.classList.toggle('mobile-open');
      }
    });
  }
});
</script>

{% schema %}
{
  "name": "Custom Mega Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact button link"
    }
  ],
  "presets": [
    {
      "name": "Custom Mega Header"
    }
  ]
}
{% endschema %}